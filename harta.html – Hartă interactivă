<main>
<p>Apasă pe marker pentru a vedea sediul CJUE.</p>
<div id="map"></div>

<script>
var map = L.map('map').setView([49.6100, 6.1300], 13); // Luxemburg
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors'
}).addTo(map);
L.marker([49.6100, 6.1300]).addTo(map)
    .bindPopup('Sediul CJUE - Luxemburg')
    .openPopup();
</script>
